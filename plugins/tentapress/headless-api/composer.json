{
    "name": "tentapress/headless-api",
    "description": "Headless REST API endpoints for TentaPress content delivery.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "tentapress/system": "<1.0",
        "tentapress/pages": "<1.0",
        "tentapress/posts": "<1.0",
        "tentapress/media": "<1.0",
        "tentapress/menus": "<1.0",
        "tentapress/settings": "<1.0",
        "tentapress/seo": "<1.0"
    },
    "autoload": {
        "psr-4": {
            "TentaPress\\HeadlessApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TentaPress\\HeadlessApi\\HeadlessApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
