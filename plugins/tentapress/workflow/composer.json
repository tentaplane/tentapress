{
    "name": "tentapress/workflow",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "tentapress/admin-shell": "<1.0",
        "tentapress/system": "<1.0",
        "tentapress/users": "<1.0",
        "tentapress/pages": "<1.0",
        "tentapress/posts": "<1.0",
        "tentapress/revisions": "<1.0"
    },
    "autoload": {
        "psr-4": {
            "TentaPress\\Workflow\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TentaPress\\Workflow\\WorkflowServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
